# === Required ===
# Google API (Gmail, Calendar)
GOOGLE_CREDENTIALS_PATH=secrets/credentials.json
GOOGLE_TOKEN_PATH=secrets/token.json

# === Optional ===
# Discord webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Gemini API (for recall_memory.py RAG search)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API (for TTS/STT)
OPENAI_API_KEY=your-openai-api-key

# Anthropic API (for statusline.sh token tracking)
CLAUDE_OAUTH_TOKEN=your-oauth-token

# IP Camera (ONVIF compatible)
CAMERA_HOST=192.168.1.100
CAMERA_USER=admin
CAMERA_PASSWORD=your-camera-password

# Email
EMAIL_ADDRESS=your-ai@gmail.com
PARTNER_EMAIL=your-partner@example.com
